# Example env file for the "shopping-card" setup.
# Copy this file to `.env` (recommended) or `.env.shopping-card` (ignored by git) and fill in real values.

# Base URLs
BASE_URL=
API_BASE_URL=

# Credentials used by UI flows (set real values locally)
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# MySQL configuration (set real values locally)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
