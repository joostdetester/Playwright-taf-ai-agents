{
  "name": "playwright-bdd-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ai:run": "ts-node ai/orchestration/agentOrchestrator.ts",
    "bddgen": "npx bddgen",
    "test": "npm run bdd",
    "bdd": "npm run bddgen && npx playwright test --reporter=list,allure-playwright",
    "bdd:dummy": "npm run bdd -- features/api/dummy-api.feature features/ui/dummy-ui.feature features/db/dummy-db.feature features/e2e/dummy-e2e.feature",
    "mcp:filesystem": "npx -y @modelcontextprotocol/server-filesystem \"C:/Users/joost/OneDrive/Documenten/Projects\"",
    "mcp:playwright": "npx @playwright/mcp@latest",
    "mcp:rest": "node C:/Users/joost/AppData/Roaming/npm/node_modules/dkmaker-mcp-rest-api/build/index.js",
    "mcp:github": "docker run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN ghcr.io/github/github-mcp-server",
    "allure:generate": "allure generate allure-results --clean -o allure-report || true",
    "allure:open": "allure open allure-report || true"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^10.0.3",
    "@playwright/test": "^1.44.0",
    "@types/node": "^25.3.0",
    "ajv": "^8.12.0",
    "allure-commandline": "^2.13.10",
    "allure-playwright": "^2.0.0",
    "dotenv": "^16.0.0",
    "ffmpeg-static": "^5.3.0",
    "glob": "^10.2.7",
    "typescript": "^5.1.6",
    "zod": "^3.21.4"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.6.0",
    "mysql2": "^3.17.5",
    "playwright-bdd": "^8.4.2"
  }
}
