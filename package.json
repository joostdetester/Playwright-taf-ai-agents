{
  "name": "playwright-bdd-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "bddgen": "npx bddgen",
    "test": "npm run bdd",
    "bdd": "npm run bddgen && npx playwright test --reporter=list,allure-playwright",
    "bdd:dummy": "npm run bdd -- features/api/dummy-api.feature features/ui/dummy-ui.feature features/db/dummy-db.feature",
    "allure:generate": "allure generate allure-results --clean -o allure-report || true",
    "allure:open": "allure open allure-report || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^25.3.0",
    "allure-commandline": "^2.13.10",
    "allure-playwright": "^2.0.0",
    "dotenv": "^16.0.0",
    "glob": "^10.2.7",
    "typescript": "^5.1.6",
    "zod": "^3.21.4"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.6.0",
    "mysql2": "^3.17.5",
    "playwright-bdd": "^8.4.2"
  }
}
